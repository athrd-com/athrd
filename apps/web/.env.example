# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
# Secret used by Better Auth. Required in production.
BETTER_AUTH_SECRET=""
# Optional explicit app URL; defaults to the incoming request origin when unset.
BETTER_AUTH_URL=""
# Public URL used when generating absolute links.
NEXT_PUBLIC_ATHRD_URL=""

# Better Auth GitHub OAuth
BETTER_AUTH_GITHUB_CLIENT_ID=""
BETTER_AUTH_GITHUB_CLIENT_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/athrd"

# Optional S3-backed thread storage. Leave blank to disable S3 locally.
ATHRD_THREADS_S3_BUCKET=""
ATHRD_THREADS_S3_REGION=""
ATHRD_THREADS_S3_ACCESS_KEY_ID=""
ATHRD_THREADS_S3_SECRET_ACCESS_KEY=""
ATHRD_THREADS_S3_ENDPOINT=""
ATHRD_THREADS_S3_VIRTUAL_HOSTED_STYLE="false"

# GitHub App
GITHUB_APP_ID=""
# Store PEM newlines as escaped "\n" when setting this in hosted env vars.
GITHUB_APP_PRIVATE_KEY=""
GITHUB_APP_WEBHOOK_SECRET=""
GITHUB_APP_SLUG=""

# Cron
CRON_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_ORG_PRICE_ID=""

# Runtime
NODE_ENV="development"
# Set to "1" only when you intentionally need to bypass env validation.
SKIP_ENV_VALIDATION=""
